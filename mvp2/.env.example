# SpinEdge Environment Variables
# Copy this file to .env and fill in the values

# Supabase credentials (required for license management)
SPINEDGE_SUPABASE_URL=https://your-project.supabase.co
SPINEDGE_SUPABASE_KEY=your-supabase-anon-key

# License validation secret (required)
SPINEDGE_MASTER_SECRET=your-master-secret

# Strategy encryption key (required for encrypted strategy bundles)
SPINEDGE_TRADE_SECRET=your-trade-secret-key
